# Keep the Docker build context small and reproducible. The Dockerfile copies
# only app/, alembic.ini, pyproject.toml, README.md and artifacts/ — everything
# else here would just bloat the context (the local venv alone is ~1.5 GB).
.venv/
venv/
mlruns/
mlartifacts/
tests/
scripts/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.env
.env.*
!artifacts/scoring_model.joblib
