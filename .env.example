# =============================================================================
# GridScore AI — environment template (twelve-factor config)
# Copy to `.env` and adjust. NEVER commit a real .env file.
# =============================================================================

# ---- Core ----
GRIDSCORE_ENV=development            # development | staging | production
GRIDSCORE_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
GRIDSCORE_LOG_JSON=false             # true => JSON logs (prod), false => console (dev)

# ---- API server ----
GRIDSCORE_API_HOST=0.0.0.0
GRIDSCORE_API_PORT=8000
GRIDSCORE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security (placeholders — replaced with real secret mgmt in later stages) ----
# Generate with: openssl rand -hex 32
GRIDSCORE_SECRET_KEY=dev-only-change-me-0000000000000000000000000000000000000000
# Salt used to hash customer identifiers at ingestion (Stage 6). Never persist raw PII.
GRIDSCORE_IDENTITY_HASH_SALT=dev-only-identity-salt-change-me

# ---- PostgreSQL ----
POSTGRES_USER=gridscore
POSTGRES_PASSWORD=gridscore
POSTGRES_DB=gridscore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL (used by the app). In docker-compose POSTGRES_HOST=postgres.
GRIDSCORE_DATABASE_URL=postgresql+asyncpg://gridscore:gridscore@localhost:5432/gridscore

# ---- Redis ----
GRIDSCORE_REDIS_URL=redis://localhost:6379/0

# ---- MLflow ----
GRIDSCORE_MLFLOW_TRACKING_URI=http://localhost:5000

# ---- Frontend (Vite) ----
# Base URL the SPA uses to reach the API.
VITE_API_BASE_URL=http://localhost:8000
